{
  "name": "openswim-podcast",
  "private": true,
  "version": "0.1.0",
  "description": "Podcast sync for swimming headphones",
  "author": "Paidia",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n vite,electron -c auto \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.10",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.paidia.openswim-podcast",
    "productName": "Open Swimcast",
    "files": [
      "electron/**",
      "dist/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "directories": {
      "buildResources": "public"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "public/icon.icns"
    }
  }
}
